{
  "manifest_version": 3,
  "name": "FormBot AI Filler",
  "version": "1.1",
  "description": "Auto-fills any web form using details saved in your FormBot AI Profile.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
     "http://localhost:3000/*",
     "https://ai-form-filling-chatbot.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
